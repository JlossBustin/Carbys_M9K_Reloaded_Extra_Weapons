VertexLitGeneric
{
	$basetexture "TTI_MPX\mpx\TLR7_lens"
	$bumpmap "TTI_MPX\mpx\NRM\TLR7_lens_n"
       "$phongexponenttexture"		"TTI_MPX\mpx\SPE\TLR7_lens_m"
        $phongexponent "30"
       
        $normalmapalphaenvmapmask   "1"
        $envmaptint   "[0.1 0.1 0.1]"
        $envmapfresnel "1" // Advanced envmap reflections
 
        $phong  "1"
        $phongboost  "5"      //tone down to decrease specular reflections
        $phongfresnelranges     "[0.25 0.75 1.00]"
        $phongalbedotint  "1"
        $nocull  1
}