"VertexLitGeneric"
{
    "$basetexture" "easy/cw/weapons/pi_t9burst/attachment_vm_pi_t9burst_laser_housing_pistol_rgb"
    "$bumpmap" "easy/cw/weapons/pi_t9burst/attachment_vm_pi_t9burst_laser_housing_pistol_n"
    "$phongexponenttexture" "easy/cw/weapons/pi_t9burst/attachment_vm_pi_t9burst_laser_housing_pistol_e"

    /////////////////
    "$color2" "[ .1 .1 .1 ]"                                    //do not touch this
    "$blendtintbybasealpha" "1"                             //do not touch this
    /////////////////

    "$phong" "1"
    "$phongboost" "1"
    "$phongexponent" "1"
    "$phongwarptexture" "phongwarp_steel"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "10"                                //toy around with this
    "$phongfresnelranges" "[ .1 .5 1 ]"
    "$basemapalphaenvmapmask" "1"
    "$envmapfresnel" "1"

    //rimlight doesn't properly show in hlmv, make sure you're changing these values in game
    "$rimlight" "1"
    "$rimlightexponent" "100"
    "$rimmask" "1"
    "$rimlightboost" "1"
       
    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    "$envmap" "easy/cw/weapons/pi_t9burst/specularity_00"
    "$envmaptint" "[0.149 0.137 0.125]"                 

    //remove this if not using MWB
    "Proxies"
    {
        "MwEnvMapTint"
        {
            "min" "0"
            "max" "1"
            "envmap" "easy/cw/weapons/pi_t9burst/specularity_00"
            "color" "[0.149 0.137 0.125]"
        }
    }
}