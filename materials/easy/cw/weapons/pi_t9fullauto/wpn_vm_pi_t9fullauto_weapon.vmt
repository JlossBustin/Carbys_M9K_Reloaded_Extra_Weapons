"VertexLitGeneric"
{
    "$basetexture" "easy/cw/weapons/pi_t9fullauto/wpn_vm_pi_t9fullauto_weapon_rgb"
    "$bumpmap" "easy/cw/weapons/pi_t9fullauto/wpn_vm_pi_t9fullauto_weapon_n"
    "$phongexponenttexture" "easy/cw/weapons/pi_t9fullauto/wpn_vm_pi_t9fullauto_weapon_e"

    /////////////////
    "$color2" "[ .3 .3 .3 ]"                                     //do not touch this
    "$blendtintbybasealpha" "1"                             //do not touch this
    /////////////////

    "$phong" "1"
    "$phongboost" "1"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "10"                                //toy around with this
    "$phongfresnelranges" "[1 0.1 0]"

    //rimlight doesn't properly show in hlmv, make sure you're changing these values in game
    "$rimlight" "1"
    "$rimlightexponent" "100"
    "$rimmask" "1"
    "$rimlightboost" "1"
       
    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    "$envmap" "easy/cw/weapons/pi_t9fullauto/specularity_00"
    "$envmaptint" "[0.141 0.141 0.145]"                 

    //remove this if not using MWB
    "Proxies"
    {
        "MwEnvMapTint"
        {
            "min" "0"
            "max" "1"
            "envmap" "easy/cw/weapons/pi_t9fullauto/specularity_00"
            "color" "[0.141 0.141 0.145]"
            "$envmap" "specularity_00"
        }
    }
}