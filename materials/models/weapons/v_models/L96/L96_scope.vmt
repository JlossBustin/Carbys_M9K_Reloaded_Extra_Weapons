"VertexLitGeneric"

{
    // MAIN SETTINGS
    "$basetexture"                "models/weapons/v_models/L96/L96_scope"
    "$bumpmap"                   "models/weapons/v_models/L96/L96_scope_n"
    "$nocull" "1"

    // PHONG SHADING
    "$phong" "1"
    "$phongboost" "0.48"
    "$phongfresnelranges"             "[.25 .5 2]"
    "$phongtint"                      "[.8 .8 1]"
    "$phongexponenttexture"           "models/weapons/v_models/L96/L96_scope_g"
    "$normalmapalphaphongmask" "1"

    // ENVIRONMENT REFLECTION
    "$envmap" "env_cubemap"
    "$envmapfresnel" "1"
    "$envmaptint"                     "[.03 .03 .03]"
    "$normalmapalphaenvmapmask" "1"

    // RIM LIGHT
    "$rimlight" "1"
    "$rimlightexponent" "200"
    "$rimlightboost" "0.04"
    "$rimmask" "1"
}